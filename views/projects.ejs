<%- include("partials/header") %>

<!-- PAGE HEADER -->
<section class="page-header projects-header">
  <div class="header-overlay">
    <div class="container text-center">
      <h1>Our Projects</h1>
      <p>Explore our precision die manufacturing and engineering work</p>
    </div>
  </div>
</section>


<!-- PROJECTS SECTION -->
<section class="projects-section">
  <div class="container">

    <% if (projects && projects.length > 0) { %>

    <div class="projects-grid">

      <% projects.forEach(project => { %>

      <div class="project-card">

        <div class="project-img">
          <img 
            src="<%= project.image?.path || project.image?.url || project.image %>" 
            alt="Project Image"
          >
        </div>

        <div class="project-content">
          <h3><%= project.title || "Project Title" %></h3>
          <p><%= project.description || "" %></p>
        </div>

      </div>

      <% }) %>

    </div>

    <% } else { %>

    <div style="text-align:center; padding:60px;">
      <h2>No Projects Found</h2>
      <p>Projects will appear here once added from the admin dashboard.</p>
    </div>

    <% } %>

  </div>
</section>

<%- include("partials/footer") %>