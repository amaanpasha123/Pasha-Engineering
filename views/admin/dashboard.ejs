<%- include("../partials/header") %>

<div class="dashboard-container">

<div class="top-bar">
<h1>Admin Dashboard</h1>
<a href="/admin/logout" class="logout-btn">Logout</a>
</div>

<a href="/admin/message" class="btn btn-dark">View Customer Messages</a>

<br><br>

<div class="dashboard-grid">

<!-- Add Project Section -->
<div class="card">

<h2>Add New Project</h2>

<form action="/admin/add-project" method="POST" enctype="multipart/form-data" class="project-form">

<input type="text" name="title" placeholder="Project Title" required>

<textarea name="description" placeholder="Project Description"></textarea>

<input type="file" name="image" required>

<button type="submit">Upload Project</button>

</form>

</div>


<!-- Projects Section -->
<div class="card">

<h2>Projects</h2>

<div class="projects-grid">
<% projects.forEach((project) => { %>

<div class="project-card">

<img src="<%= project.image %>" alt="Project Image">

<div class="project-info">

<h3><%= project.title %></h3>

<p><%= project.description %></p>

<form action="/admin/delete-project/<%= project._id %>" method="POST">
<button class="delete-btn">Delete</button>
</form>

</div>

</div>

<% }) %>

</div>

</div>

</div>

</div>

<%- include("../partials/footer") %>